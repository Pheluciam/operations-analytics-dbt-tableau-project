# The only secret this project needs: the local Postgres password, supplied via
# the standard libpq PGPASSWORD environment variable. Set it once, permanently
# (new terminals only — restart VS Code after):
#   PowerShell:  [Environment]::SetEnvironmentVariable('PGPASSWORD','your_postgres_password','User')
# profiles.yml reads it via env_var('PGPASSWORD'); psql picks it up natively.
PGPASSWORD=your_postgres_password_here
